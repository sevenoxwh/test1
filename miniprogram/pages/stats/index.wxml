<view class="page-container">
  <!-- 总览卡片 -->
  <view class="overview-card card">
    <view class="overview-item">
      <text class="overview-value">{{totalCheckins}}</text>
      <text class="overview-label">累计打卡</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">{{totalDuration}}</text>
      <text class="overview-label">运动时长(分)</text>
    </view>
    <view class="overview-item">
      <text class="overview-value">{{totalCalories}}</text>
      <text class="overview-label">消耗千卡</text>
    </view>
  </view>

  <!-- 运动类型分布 -->
  <view class="section card">
    <text class="section-title">运动类型分布</text>
    <view class="sport-distribution">
      <view 
        wx:for="{{sportStats}}" 
        wx:key="sport"
        class="sport-stat-item"
      >
        <view class="sport-info">
          <text class="sport-name">{{item.sport}}</text>
          <text class="sport-count">{{item.count}} 次</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.percent}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近7天打卡 -->
  <view class="section card">
    <text class="section-title">最近7天打卡</text>
    <view class="week-calendar">
      <view 
        wx:for="{{weekDays}}" 
        wx:key="date"
        class="week-day {{item.checked ? 'checked' : ''}}"
      >
        <text class="week-day-name">{{item.dayName}}</text>
        <view class="check-dot {{item.checked ? 'active' : ''}}"></view>
      </view>
    </view>
  </view>
</view>
