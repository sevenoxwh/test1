.page-container {
  padding: var(--spacing-md);
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
}

/* 日历卡片 */
.calendar-card {
  margin-bottom: var(--spacing-lg);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.calendar-nav {
  display: flex;
  gap: var(--spacing-sm);
}

.nav-btn {
  font-size: 40rpx;
  color: var(--color-text-secondary);
  padding: 0 16rpx;
}

.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: var(--spacing-sm);
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 0;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  position: relative;
}

.day-number {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.day-cell.today {
  border: 2rpx solid var(--color-primary);
}

.day-cell.today .day-number {
  font-weight: 600;
}

.day-cell.other-month .day-number {
  color: var(--color-text-disabled);
}

.checkin-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 4rpx;
}

/* 连击区域 */
.streak-section {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.streak-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--spacing-sm);
}

.streak-number {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: var(--spacing-md);
}

.streak-value {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
  letter-spacing: -2rpx;
}

.streak-unit {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-left: 8rpx;
}

.streak-stats {
  display: flex;
  justify-content: center;
  gap: var(--spacing-lg);
}

.stat-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 打卡按钮 */
.checkin-btn-wrapper {
  margin-top: var(--spacing-xl);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.checkin-btn {
  background: var(--color-primary);
  color: var(--color-surface);
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: var(--radius-md);
  text-align: center;
  transition: all 300ms ease;
}

.checkin-btn:active {
  transform: scale(0.98);
  background: #374151;
}

.checkin-btn.checked {
  background: var(--color-secondary);
}

/* AI 可拖动悬浮按钮 */
.ai-fab-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
}

.ai-fab {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  pointer-events: auto;
}

.ai-fab:active {
  transform: scale(0.95);
  background: #374151;
}

.ai-fab-icon {
  color: var(--color-surface);
  font-size: 40rpx;
}
