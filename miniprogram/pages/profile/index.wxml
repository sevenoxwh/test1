<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card card" bindtap="goToEditProfile">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/icons/avatar.png'}}" mode="aspectFill"/>
    <text class="nickname">{{userInfo.nickName || '健身达人'}}</text>
    <text class="edit-hint">点击编辑资料 ›</text>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToBodyArchive">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-text">身体档案</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToStats">
      <view class="menu-left">
        <text class="menu-icon">📈</text>
        <text class="menu-text">数据统计</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAiChat">
      <view class="menu-left">
        <text class="menu-icon">✦</text>
        <text class="menu-text">AI 健身问答</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPoster">
      <view class="menu-left">
        <text class="menu-icon">🖼️</text>
        <text class="menu-text">分享海报</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>FitCheck v1.0</text>
  </view>
</view>
