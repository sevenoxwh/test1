.page-container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #F9FAFB;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  margin-bottom: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  background: #E5E7EB;
}

.avatar-hint {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 表单区域 */
.form-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #111827;
  background: #FFFFFF;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #111827;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #111827;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
}

.save-btn.disabled {
  opacity: 0.6;
}
